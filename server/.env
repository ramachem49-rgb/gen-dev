PORT=5000
MONGODB_URI=mongodb://localhost:27017/learning_platform
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRE=30d
NODE_ENV=development
FRONTEND_URL=http://localhost:5173
# Database Hiding Configuration
ALLOWED_DB_IPS=192.168.1.100,10.0.0.50
ENABLE_FAKE_DB=true
REQUIRE_PORT_KNOCKING=true
KNOCK_SEQUENCE=10001,10002,10003,10004,10005
VPN_REQUIRED=false
GEO_RESTRICTION_ENABLED=true
ALLOWED_COUNTRIES=KH,US,SG

# Port Randomization
PORT_ROTATION_DAYS=30
MIN_DB_PORT=49152
MAX_DB_PORT=65535

# Proxy Configuration
DB_PROXY_PORT=40000
PROXY_REQUIRE_AUTH=true
# Anti-Clone Configuration
DOMAIN=yourdomain.com
WATERMARK_SECRET=your_watermark_secret_key_change_this
DATABASE_SECRET=your_database_secret_key_change_this
DATABASE_SALT=your_database_salt_change_this
OBFUSCATION_KEY=your_obfuscation_key_change_this

# Monitoring
GOOGLE_SAFE_BROWSING_API_KEY=your_google_api_key
CLOUDFLARE_API_KEY=your_cloudflare_api_key
CLOUDFLARE_ZONE_ID=your_zone_id

# DMCA Contact
DMCA_EMAIL=dmca@yourdomain.com
ABUSE_EMAIL=abuse@yourdomain.com

# Telegram Bot Configuration
TELEGRAM_BOT_TOKEN=8529631483:AAHBJ_9-d-5DJ5URyynAjhzw3VPGe_fC4bs
TELEGRAM_CHAT_ID=8115857668

# Security Configuration
ENABLE_SECURITY_ALERTS=true
ENABLE_DDOS_PROTECTION=true
MAX_REQUESTS_PER_MINUTE=100
BLOCK_DURATION_DAYS=7
ENABLE_GEOIP=true